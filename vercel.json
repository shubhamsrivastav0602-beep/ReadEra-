{
  "buildCommand": "npm install || true",
  "outputDirectory": ".",
  "functions": {
    "api/index.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/summaries/(.*)",
      "dest": "/summaries/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
